{
  "@context": {
    "@version": 1.1,
    "kotoba": "https://github.com/com-junkawasaki/kotoba/blob/22712d997449ec6229800adf42698936aa24b386/schemas/kotoba-context.jsonld#vocab",
    "sh": "http://www.w3.org/ns/shacl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@id": "https://kotoba.ai/shapes/ir",
  "@type": "sh:NodeShape",
  "rdfs:comment": "SHACL shapes for validating Intermediate Representation (IR) structures",
  
  "@graph": [
    {
      "@id": "kotoba:IRShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": "kotoba:IR",
      "sh:property": [
        {
          "sh:path": "kotoba:hasCID",
          "sh:datatype": "xsd:string",
          "sh:minCount": 0,
          "sh:maxCount": 1,
          "sh:pattern": "^[A-Za-z0-9_=-]{10,128}$"
        },
        {
          "sh:path": "kotoba:hasName",
          "sh:datatype": "xsd:string",
          "sh:minCount": 0,
          "sh:maxCount": 1
        }
      ]
    },
    {
      "@id": "kotoba:RuleIRShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": "kotoba:RuleIR",
      "sh:property": [
        {
          "sh:path": "kotoba:name",
          "sh:datatype": "xsd:string",
          "sh:minCount": 1,
          "sh:maxCount": 1
        },
        {
          "sh:path": "kotoba:lhs",
          "sh:node": "kotoba:GraphPatternShape",
          "sh:minCount": 1,
          "sh:maxCount": 1
        },
        {
          "sh:path": "kotoba:rhs",
          "sh:node": "kotoba:GraphPatternShape",
          "sh:minCount": 1,
          "sh:maxCount": 1
        },
        {
          "sh:path": "kotoba:context",
          "sh:node": "kotoba:GraphPatternShape",
          "sh:minCount": 0,
          "sh:maxCount": 1
        },
        {
          "sh:path": "kotoba:nacs",
          "sh:node": "kotoba:GraphPatternShape",
          "sh:minCount": 0
        },
        {
          "sh:path": "kotoba:guards",
          "sh:minCount": 0
        },
        {
          "sh:path": "kotoba:types",
          "sh:minCount": 0
        }
      ]
    },
    {
      "@id": "kotoba:QueryIRShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": "kotoba:QueryIR",
      "sh:property": [
        {
          "sh:path": "kotoba:plan",
          "sh:node": "kotoba:LogicalOpShape",
          "sh:minCount": 1,
          "sh:maxCount": 1
        }
      ]
    },
    {
      "@id": "kotoba:PatchIRShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": "kotoba:PatchIR",
      "sh:property": [
        {
          "sh:path": "kotoba:adds",
          "sh:node": "kotoba:PatchAddsShape",
          "sh:minCount": 0,
          "sh:maxCount": 1
        },
        {
          "sh:path": "kotoba:dels",
          "sh:node": "kotoba:PatchDelsShape",
          "sh:minCount": 0,
          "sh:maxCount": 1
        },
        {
          "sh:path": "kotoba:updates",
          "sh:node": "kotoba:PatchUpdatesShape",
          "sh:minCount": 0,
          "sh:maxCount": 1
        }
      ]
    },
    {
      "@id": "kotoba:StrategyIRShape",
      "@type": "sh:NodeShape",
      "sh:targetClass": "kotoba:StrategyIR",
      "sh:property": [
        {
          "sh:path": "kotoba:strategy",
          "sh:node": "kotoba:StrategyOpShape",
          "sh:minCount": 1,
          "sh:maxCount": 1
        }
      ]
    },
    {
      "@id": "kotoba:GraphPatternShape",
      "@type": "sh:NodeShape",
      "sh:property": [
        {
          "sh:path": "kotoba:nodes",
          "sh:minCount": 0
        },
        {
          "sh:path": "kotoba:edges",
          "sh:minCount": 0
        }
      ]
    },
    {
      "@id": "kotoba:LogicalOpShape",
      "@type": "sh:NodeShape",
      "sh:property": [
        {
          "sh:path": "kotoba:op",
          "sh:datatype": "xsd:string",
          "sh:minCount": 1,
          "sh:maxCount": 1
        }
      ]
    },
    {
      "@id": "kotoba:StrategyOpShape",
      "@type": "sh:NodeShape",
      "sh:property": [
        {
          "sh:path": "kotoba:op",
          "sh:datatype": "xsd:string",
          "sh:minCount": 1,
          "sh:maxCount": 1,
          "sh:in": [
            {"@value": "once"},
            {"@value": "exhaust"},
            {"@value": "while"},
            {"@value": "seq"},
            {"@value": "choice"},
            {"@value": "priority"}
          ]
        }
      ]
    },
    {
      "@id": "kotoba:PatchAddsShape",
      "@type": "sh:NodeShape",
      "sh:property": [
        {
          "sh:path": "kotoba:vertices",
          "sh:minCount": 0
        },
        {
          "sh:path": "kotoba:edges",
          "sh:minCount": 0
        }
      ]
    },
    {
      "@id": "kotoba:PatchDelsShape",
      "@type": "sh:NodeShape",
      "sh:property": [
        {
          "sh:path": "kotoba:vertices",
          "sh:minCount": 0
        },
        {
          "sh:path": "kotoba:edges",
          "sh:minCount": 0
        }
      ]
    },
    {
      "@id": "kotoba:PatchUpdatesShape",
      "@type": "sh:NodeShape",
      "sh:property": [
        {
          "sh:path": "kotoba:props",
          "sh:minCount": 0
        },
        {
          "sh:path": "kotoba:relinks",
          "sh:minCount": 0
        }
      ]
    }
  ]
}

