{
  "@context": "../../schemas/kotoba-context.jsonld",
  "@type": "kotoba:Crate",
  "@id": "kotoba:crate/kotoba-kotobas",
  "name": "kotoba-kotobas",
  "version": "0.1.22",
  "path": "crates/020-language/023-kotoba-kotobas",
  "status": "active",
  "edition": "2021",
  "license": "Apache-2.0",
  "repository": "https://github.com/com-junkawasaki/kotoba",
  "description": "KotobaScript - Declarative programming language for frontend applications, extending Jsonnet with React component definitions",
  "keywords": [
    "jsonnet",
    "programming-language",
    "frontend",
    "react",
    "declarative"
  ],
  "categories": [
    "config",
    "template-engine",
    "web-programming",
    "development-tools"
  ],
  "layer": "kotoba:layer/020-language",
  "dependencies": {
    "workspace": [
      {
        "type": "workspace",
        "path": "../../010-logic/019-kotoba-jsonld",
        "name": "kotoba-jsonld"
      },
      {
        "type": "workspace",
        "path": "../../010-logic/009-kotoba-logic",
        "name": "kotoba-logic"
      },
      {
        "type": "workspace",
        "path": "../../010-logic/010-kotoba-types",
        "name": "kotoba-types"
      },
      {
        "type": "workspace",
        "path": "../../010-logic/011-kotoba-ir",
        "name": "kotoba-ir"
      },
      {
        "type": "workspace",
        "path": "../../010-logic/012-kotoba-rewrite-kernel",
        "name": "kotoba-rewrite-kernel"
      },
      {
        "type": "workspace",
        "path": "../020-kotoba-syntax",
        "name": "kotoba-syntax"
      },
      {
        "type": "workspace",
        "path": "../021-kotoba-parser",
        "name": "kotoba-parser"
      },
      {
        "type": "workspace",
        "path": "../022-kotoba-analyzer",
        "name": "kotoba-analyzer"
      },
      {
        "type": "workspace",
        "path": "../023-kotoba-jsonnet",
        "name": "kotoba-jsonnet"
      }
    ],
    "external": [
      {
        "type": "external",
        "version": "1.0",
        "features": [
          "derive"
        ],
        "name": "serde"
      },
      {
        "name": "serde_json",
        "type": "external",
        "version": "1.0"
      },
      {
        "name": "thiserror",
        "type": "external",
        "version": "2.0"
      },
      {
        "name": "anyhow",
        "type": "external",
        "version": "1.0"
      },
      {
        "name": "regex",
        "type": "external",
        "version": "1.10"
      },
      {
        "type": "external",
        "version": "1.18",
        "features": [
          "v4"
        ],
        "name": "uuid"
      },
      {
        "type": "external",
        "version": "0.11",
        "features": [
          "json"
        ],
        "name": "reqwest"
      },
      {
        "name": "sha2",
        "type": "external",
        "version": "0.10"
      },
      {
        "name": "base64",
        "type": "external",
        "version": "0.21"
      },
      {
        "type": "external",
        "version": "0.4",
        "features": [
          "serde"
        ],
        "name": "chrono"
      }
    ],
    "optional": [
      {
        "type": "external",
        "version": "1.0",
        "optional": true,
        "features": [
          "full"
        ],
        "name": "tokio"
      }
    ],
    "dev": [
      {
        "type": "external",
        "version": "1.0",
        "features": [
          "full"
        ],
        "name": "tokio"
      },
      {
        "name": "tempfile",
        "type": "external",
        "version": "3.0"
      }
    ]
  },
  "features": {
    "default": [
      "async"
    ],
    "optional": [
      "async"
    ]
  },
  "sourceFiles": [
    "src/ai_chains.rs",
    "src/ai_memory.rs",
    "src/ai_models.rs",
    "src/ai_parser.rs",
    "src/ai_runtime.rs",
    "src/ai_tools.rs",
    "src/config.rs",
    "src/deploy.rs",
    "src/error.rs",
    "src/frontend.rs",
    "src/github_pages.rs",
    "src/http_parser.rs",
    "src/lib.rs"
  ]
}