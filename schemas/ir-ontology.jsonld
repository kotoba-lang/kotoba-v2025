{
  "@context": {
    "@version": 1.1,
    "kotoba": "https://github.com/com-junkawasaki/kotoba/blob/22712d997449ec6229800adf42698936aa24b386/schemas/kotoba-context.jsonld#vocab",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "sh": "http://www.w3.org/ns/shacl#"
  },
  "@id": "https://kotoba.ai/ontology/ir",
  "@type": "owl:Ontology",
  "rdfs:comment": "Intermediate Representation (IR) ontology for Kotoba. Defines the type hierarchy for Rule-IR, Query-IR, Patch-IR, and Strategy-IR using OWL classes.",
  
  "@graph": [
    {
      "@id": "kotoba:IR",
      "@type": "owl:Class",
      "rdfs:label": "Intermediate Representation",
      "rdfs:comment": "Abstract base class for all intermediate representations in Kotoba",
      "rdfs:subClassOf": {
        "@id": "rdfs:Resource"
      }
    },
    {
      "@id": "kotoba:RuleIR",
      "@type": "owl:Class",
      "rdfs:label": "Rule Intermediate Representation",
      "rdfs:comment": "DPO (Double Pushout) typed attribute graph rewriting rule IR",
      "rdfs:subClassOf": {
        "@id": "kotoba:IR"
      }
    },
    {
      "@id": "kotoba:QueryIR",
      "@type": "owl:Class",
      "rdfs:label": "Query Intermediate Representation",
      "rdfs:comment": "GQL logical plan algebra IR",
      "rdfs:subClassOf": {
        "@id": "kotoba:IR"
      }
    },
    {
      "@id": "kotoba:PatchIR",
      "@type": "owl:Class",
      "rdfs:label": "Patch Intermediate Representation",
      "rdfs:comment": "Differential expression IR (addV/E, delV/E, setProp, relink)",
      "rdfs:subClassOf": {
        "@id": "kotoba:IR"
      }
    },
    {
      "@id": "kotoba:StrategyIR",
      "@type": "owl:Class",
      "rdfs:label": "Strategy Intermediate Representation",
      "rdfs:comment": "Minimal strategy expression IR (once|exhaust|while|seq|choice|priority)",
      "rdfs:subClassOf": {
        "@id": "kotoba:IR"
      }
    },
    {
      "@id": "kotoba:CatalogIR",
      "@type": "owl:Class",
      "rdfs:label": "Catalog Intermediate Representation",
      "rdfs:comment": "Schema/index/invariant definition IR",
      "rdfs:subClassOf": {
        "@id": "kotoba:IR"
      }
    },
    {
      "@id": "kotoba:hasCID",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has Content ID",
      "rdfs:comment": "Content-addressable identifier for IR instances",
      "rdfs:domain": {
        "@id": "kotoba:IR"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      }
    },
    {
      "@id": "kotoba:hasName",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has name",
      "rdfs:comment": "Name identifier for IR instances",
      "rdfs:domain": {
        "@id": "kotoba:IR"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      }
    },
    {
      "@id": "kotoba:hasMetadata",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has metadata",
      "rdfs:comment": "Metadata associated with IR instances",
      "rdfs:domain": {
        "@id": "kotoba:IR"
      }
    }
  ]
}

