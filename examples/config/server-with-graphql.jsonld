{
  "@context": "https://github.com/com-junkawasaki/kotoba/blob/22712d997449ec6229800adf42698936aa24b386/schemas/kotoba-context.jsonld",
  "@type": "kotoba:ServerConfig",
  "@id": "file://examples/config/server-with-graphql.jsonld",
  "kotoba:server": {
    "@type": "kotoba:ServerSettings",
    "kotoba:host": "127.0.0.1",
    "kotoba:port": 8080,
    "kotoba:max_connections": 1000,
    "kotoba:timeout_ms": 30000,
    "kotoba:graphql_enabled": true
  },
  "kotoba:routes": {
    "@container": "@set",
    "@type": "kotoba:Route"
  },
  "kotoba:middlewares": {
    "@container": "@set",
    "@type": "kotoba:Middleware"
  }
}

